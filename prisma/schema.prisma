// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  persons       Person[]
  supplements   Supplement[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Person {
  id                Int                @id @default(autoincrement())
  name              String
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplementPersons SupplementPerson[]
  skippedIntakes    SkippedIntake[]
  deductionLogs     DeductionLog[]
}

model SupplementPerson {
  id           Int        @id @default(autoincrement())
  personId     Int
  supplementId Int
  takingDaily  Boolean    @default(false)
  unitsPerDay  Int?
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  supplement   Supplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)

  @@unique([personId, supplementId])
}

model Supplement {
  id               Int                @id @default(autoincrement())
  activeIngredient String
  dosePerUnit      String
  amountOfUnits    Int
  amountOfPackages Int
  brand            String
  source           String
  costPerPackage   Float
  unitsLeft        Int?
  packageUnits     String?
  packageSetAt     DateTime?
  order            Int                @default(0)
  createdAt        DateTime           @default(now())
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  persons          SupplementPerson[]
  skippedIntakes   SkippedIntake[]
  deductionLogs    DeductionLog[]
}

model DeductionLog {
  id            Int        @id @default(autoincrement())
  date          DateTime
  personId      Int
  supplementId  Int
  unitsDeducted Int
  source        String     @default("auto")
  reversed      Boolean    @default(false)
  person        Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  supplement    Supplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)

  @@unique([date, personId, supplementId])
}

model Settings {
  key   String @id
  value String
}

model SkippedIntake {
  id           Int        @id @default(autoincrement())
  date         DateTime
  personId     Int
  supplementId Int
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  supplement   Supplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)

  @@unique([date, personId, supplementId])
}
