// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Person {
  id                Int                @id @default(autoincrement())
  name              String
  supplementPersons SupplementPerson[]
  skippedIntakes    SkippedIntake[]
}

model SupplementPerson {
  id           Int        @id @default(autoincrement())
  personId     Int
  supplementId Int
  takingDaily  Boolean    @default(false)
  unitsPerDay  Int?
  startDate    DateTime?
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  supplement   Supplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)

  @@unique([personId, supplementId])
}

model Supplement {
  id               Int                @id @default(autoincrement())
  activeIngredient String
  dosePerUnit      String
  amountOfUnits    Int
  amountOfPackages Int
  brand            String
  source           String
  costPerPackage   Float
  unitsLeft        Int?
  packageUnits     String?
  packageSetAt     DateTime?
  createdAt        DateTime           @default(now())
  persons          SupplementPerson[]
  skippedIntakes   SkippedIntake[]
}

model Settings {
  key   String @id
  value String
}

model SkippedIntake {
  id           Int        @id @default(autoincrement())
  date         DateTime
  personId     Int
  supplementId Int
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  supplement   Supplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)

  @@unique([date, personId, supplementId])
}
